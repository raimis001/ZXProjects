1010 LET k$=INKEY$

1020 IF k$ = " " THEN GO TO 9999

1030 IF k$ = "d" THEN GO SUB 5500
1040 IF k$ = "a" THEN GO SUB 5550
1050 IF k$ = "s" THEN GO SUB 7000

1060 IF v > 0 THEN GO TO 9500

1099 PAUSE 10
1100 GO TO 1000

4950 INK 6
