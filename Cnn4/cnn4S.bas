4970 LET x=px: LET y=py
5000 REM draw token AT X and Y position
5010 PRINT AT y+0, x*3-1; c$(1)
5020 PRINT AT y+1, x*3-1; c$(2)
5050 RETURN

5059 LET x=px: LET y=py
5060 REM clear token
5070 PRINT AT y+0, x*3-1; "  "
5080 PRINT AT y+1, x*3-1; "  "
5090 RETURN

5500 REM move right
5510 IF px < 7 THEN LET dx = 1: GO SUB 5600
5549 RETURN

5550 REM move right
5560 IF px > 1 THEN LET dx = -1: GO SUB 5600
5599 RETURN

5600 REM move dx
5610 GO SUB 5059
5620 LET px = px + dx
5630 GO SUB 4950
5699 RETURN

6000 REM draw board
6010 INK 1
6020 FOR j = 1 TO 7: FOR i = 1 TO 23
6040 READ d
6050 PRINT AT py+j+1, i-1; CHR$ d
6060 NEXT i: NEXT j
6099 RETURN

7000 REM drop token
7010 FOR i = 6 TO 1 STEP -1
7020 IF t(i,px) = 0 THEN GO SUB 7200: RETURN
7050 NEXT i
7199 RETURN

7200 REM assign
7210 INK 6: IF p=1 THEN INK 2
7220 LET t(i,px)=p
7230 LET x=px: LET y = py + i*2: GO SUB 5000
7235 GO SUB 8000: IF v>0 THEN RETURN
7240 LET p=p+1: IF p > 2 THEN LET p=1
7250 LET dx = 0: GO SUB 5600
7299 RETURN

8000 REM check 

8010 LET g=0 
8020 FOR j=i TO 6
8030 LET tt=t(j,px)
8040 IF tt=0 OR tt<>p THEN GO TO 8100
8050 LET g = g+1
8060 IF g > 3 THEN LET v=p: RETURN
8070 NEXT j

8050 IF tt=0 OR tt<>pl then GOTO 8100
8100 REM horizontal
8110 LET g=0
8120 LET x1=px-3:IF x1<1 THEN LET x1=1
8130 LET x2=px+3:IF x2>7 THEN LET x2=7
8140 FOR j=x1 TO x2
8150 LET tt=t(i,j)
8160 IF tt=0 OR tt<>p THEN LET g=0
8170 IF tt=p THEN LET g=g+1
8180 IF g > 3 THEN LET v=p: RETURN
8190 NEXT j

8200 REM diogonal h
8210 LET dy=-1
8220 LET g=0
8230 LET x1=px: LET y1=i
8240 LET x1=x1-1: LET y1=y1+dy
8250 IF x1<1 OR y1<1 OR y1>6 THEN GO TO 8260
8253 LET g=g+1
8255 IF g<4 THEN GO TO 8240

8300 LET x1=x1+1: LET y1=y1-dy: LET g=0
8310 FOR j=0 TO 7
8320 LET tt=t(y1,x1)
8330 IF tt=0 OR tt<>p THEN LET g=0
8340 IF tt=p THEN LET g=g+1
8350 IF g > 3 THEN LET v=p: RETURN
8360 LET x1=x1+1: LET y1=y1-dy
8370 IF x1>7 OR y1 > 6 OR y1 < 1 THEN GO TO 8400
8380 NEXT j

8400 REM diogonal v
8410 IF dy=1 THEN RETURN
8420 LET dy=1
8430 GO TO 8220

8999 RETURN

